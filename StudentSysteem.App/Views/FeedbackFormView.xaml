<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StudentSysteem.App.ViewModels"
             x:Class="StudentSysteem.App.Views.FeedbackFormView"
             Title="Feedbackformulier">


    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Text="Dashboard" />
                <Label Text="Feedbackformulier" Grid.Column="1"
                       FontSize="22" HorizontalOptions="Center" />
                <Image Source="person_icon.png" Grid.Column="2" HeightRequest="40"/>
            </Grid>

            <Line Stroke="Black" X2="2000" />

            <Label Text="Requirementsanalyseproces - Definiëren probleemdomein" />
            <Label Text="Analyseren" FontAttributes="Italic" />
            <Label Text="Maken domeinmodel" FontAttributes="Bold" />
            <Label Text="Het maken van een domeinmodel volgens een UML klassendiagram" />

            <Label Text="Prestatiedoel" FontSize="20"/>
            <Label Text="Maak een domeinmodel volgens een UML klassendiagram en leg deze vast in je plan en/of ontwerpdocumenten" />

            <!-- Picker met rode border -->
            <Frame BorderColor="{Binding IsPrestatieNiveauInvalid, Converter={StaticResource BoolToColorConverter}}"
           BackgroundColor="White"
           Padding="10"
           HasShadow="False">
        <StackLayout Spacing="10">

        <!-- Vak 1: In ontwikkeling -->
    <Frame BackgroundColor="#f0f0f0" Padding="10" CornerRadius="5">
        <StackLayout Spacing="5">
            <Label Text="In ontwikkeling" FontAttributes="Bold"/>
        </StackLayout>
    </Frame>

    <!-- Vak 2: Op niveau -->
    <Frame BackgroundColor="#f0f0f0" Padding="10" CornerRadius="5">
        <StackLayout Spacing="5">
            <Label Text="Op niveau" FontAttributes="Bold"/>
            <StackLayout Spacing="5">
                <StackLayout Orientation="Horizontal" Spacing="10">
                    <CheckBox IsChecked="{Binding OpNiveauOptie1}" />
                    <Label Text="Het domeinmodel weerspiegelt het domein" VerticalOptions="Center"/>
                </StackLayout>
                <StackLayout Orientation="Horizontal" Spacing="10">
                    <CheckBox IsChecked="{Binding OpNiveauOptie2}" />
                    <Label Text="De syntax van het domeinmodel is correct volgens UML" VerticalOptions="Center"/>
                </StackLayout>
                <StackLayout Orientation="Horizontal" Spacing="10">
                    <CheckBox IsChecked="{Binding OpNiveauOptie3}" />
                    <Label Text="Het domeinmodel is op een logische locatie vastgelegd" VerticalOptions="Center"/>
                </StackLayout>
            </StackLayout>
        </StackLayout>
    </Frame>

    <!-- Vak 3: Boven niveau -->
    <Frame BackgroundColor="#f0f0f0" Padding="10" CornerRadius="5">
        <StackLayout Spacing="5">
            <Label Text="Boven niveau" FontAttributes="Bold"/>
            <StackLayout Spacing="5">
                <StackLayout Orientation="Horizontal" Spacing="10">
                    <CheckBox IsChecked="{Binding BovenNiveauOptie1}" />
                    <Label Text="Het domeinmodel is volledig, helder en sluit logisch aan bij de context van het project" VerticalOptions="Center"/>
                </StackLayout>
            </StackLayout>
        </StackLayout>
    </Frame>

    </StackLayout>
</Frame>

            <Editor HeightRequest="150"
                    Placeholder="Voeg toelichting toe..."
                    Text="{Binding Toelichting}" />

            <Label Text="{Binding StatusMelding}" 
                   TextColor="Red"
                   FontAttributes="Bold"/>

            <Button Text="Opslaan"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#0066cc"
                    TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>


